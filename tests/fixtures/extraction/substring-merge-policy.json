      "longerName": "달빛 기사 세린",
      "type": "CHARACTER",
      "expected": false
    },
    {
      "shorterName": "수인",
      "longerName": "늑대 수인",
      "type": "CONCEPT",
      "expected": false
    },
    {
      "shorterName": "탑",
      "longerName": "검은 탑",
