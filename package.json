{
  "name": "smart-writer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "knip": "knip --include files,dependencies",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:e2e": "playwright test",
    "test:all": "npm run test:run && npm run test:integration && npm run test:e2e",
    "seed:e2e": "npx --yes tsx scripts/e2e-seed.ts",
    "cleanup:e2e": "npx --yes tsx scripts/e2e-cleanup.ts",
    "cleanup:e2e:apply": "npx --yes tsx scripts/e2e-cleanup.ts --apply",
    "db:replay-verify": "bash scripts/db-replay-verify.sh",
    "ops:extraction-eval:smoke": "npx --yes tsx scripts/ops/run-extraction-eval.ts --tier=smoke",
    "ops:extraction-eval:full": "npx --yes tsx scripts/ops/run-extraction-eval.ts --tier=full",
    "ops:extraction-eval:build-golden": "npx --yes tsx scripts/ops/build-extraction-golden.ts",
    "ops:extraction-eval:build-drift-golden": "npx --yes tsx scripts/ops/build-drift-golden.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^25.0.1",
    "knip": "^6.26.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
